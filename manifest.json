{
  "manifest_version": 3,
  "name": "Always Open PDFs",
  "version": "1.0.0",
  "description": "Automatically opens PDF files in your browser whenever possible.",

  "permissions": [
    "storage",
    "tabs",
    "downloads"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "action": {
    "default_title": "Always Open PDFs",
    "default_popup": "popup/popup.html"
  },

  "options_page": "options/options.html",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
